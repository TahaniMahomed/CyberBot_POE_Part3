<Window x:Class="CyberBot_POE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aegis-X - Cybersecurity Sentinel &amp; Task Hub" 
        Height="650" Width="900"
        Background="#0A0A14"
        Loaded="Window_Loaded">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="15" BorderThickness="2" Margin="0,0,0,10" Padding="10">
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#00FFFF" Offset="0.0"/>
                        <GradientStop Color="#BF40BF" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <TextBlock x:Name="AsciiDisplay" TextAlignment="Center" FontFamily="Courier New" FontWeight="Bold" Foreground="#00FFFF"/>
            </Border>

            <ScrollViewer Grid.Row="1" x:Name="MainScrollViewer" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ChatContainer" VerticalAlignment="Top"/>
            </ScrollViewer>

            <Grid Grid.Row="2" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="UserInputBox" Height="40" Background="#1A1A2E" Foreground="White" BorderBrush="#BF40BF" BorderThickness="1.5" VerticalContentAlignment="Center" Padding="10,0" KeyDown="UserInputBox_KeyDown"/>
                <Button Grid.Column="1" Content="SEND" Width="80" Margin="10,0,0,0" Click="SendButton_Click" Background="#BF40BF" Foreground="White" FontWeight="Bold"/>
            </Grid>
        </Grid>

        <Rectangle Grid.Column="1" Width="2" Fill="#1A1A2E" Margin="0,5"/>

        <Grid Grid.Column="2" Margin="10,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="10" BorderThickness="1" BorderBrush="#00FFFF" Background="#111126" Padding="10" Margin="0,0,0,10">
                <TextBlock Text="SECURITY TASKS" HorizontalAlignment="Center" Foreground="#00FFFF" FontWeight="Bold" FontSize="14"/>
            </Border>

            <DataGrid Grid.Row="1" x:Name="TasksDataGrid" 
                      Background="#141428" Foreground="White" RowBackground="#141428" 
                      AlternatingRowBackground="#1E1E32" BorderBrush="#00FFFF"
                      AutoGenerateColumns="True" HeadersVisibility="Column"
                      CanUserResizeColumns="False">
                <DataGrid.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="TextWrapping" Value="Wrap"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#00FFFF"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
            </DataGrid>

            <Grid Grid.Row="2" Margin="0,10,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="COMPLETE" Click="CompleteTaskButton_Click" Background="#28A745" Foreground="White" Margin="0,0,5,0"/>
                <Button Grid.Column="1" Content="DELETE" Click="DeleteTaskButton_Click" Background="#DC3545" Foreground="White" Margin="5,0,5,0"/>
                <Button Grid.Column="2" Content="🔄 REFRESH" Click="RefreshTasksButton_Click" Background="#00FFFF" Foreground="Black" Margin="5,0,0,0"/>
            </Grid>
            <Border Grid.Row="3" Margin="0,10,0,0" Background="#1A1A2E" Padding="10">
                <StackPanel VerticalAlignment="Bottom">
                    <TextBlock x:Name="QuestionDisplay" 
                   Text="Press START to begin the Cybersecurity Quiz" 
                   Foreground="Cyan" 
                   TextAlignment="Center" 
                   FontSize="14" 
                   Margin="0,0,0,10"/>

                    <StackPanel x:Name="QuizButtonContainer" 
                    Orientation="Vertical" 
                    HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window> 