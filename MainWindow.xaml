<Window x:Class="CyberBot_POE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aegis-X - Cybersecurity Sentinel &amp; Task Hub" Height="650" Width="900"
        Background="#0A0A14">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="15" BorderThickness="2" Margin="0,0,0,10" Padding="10">
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#00FFFF" Offset="0.0"/>
                        <GradientStop Color="#BF40BF" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <TextBlock x:Name="AsciiDisplay" TextAlignment="Center" 
                           FontFamily="Courier New" FontWeight="Bold" Foreground="#00FFFF">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#00FFFF" BlurRadius="10" ShadowDepth="0"/>
                    </TextBlock.Effect>
                </TextBlock>
            </Border>

            <ScrollViewer Grid.Row="1" x:Name="MainScrollViewer" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ChatContainer" VerticalAlignment="Top"/>
            </ScrollViewer>

            <Grid Grid.Row="2" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="UserInputBox" Height="40" Background="#1A1A2E" 
                         Foreground="White" BorderBrush="#BF40BF" BorderThickness="1.5" 
                         VerticalContentAlignment="Center" Padding="10,0"
                         KeyDown="UserInputBox_KeyDown"/>

                <Button Grid.Column="1" Content="SEND" Width="80" Margin="10,0,0,0"
                        Click="SendButton_Click" Cursor="Hand"
                        Background="#BF40BF" Foreground="White" FontWeight="Bold">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                    <Button.Effect>
                        <DropShadowEffect Color="#BF40BF" BlurRadius="8" ShadowDepth="0"/>
                    </Button.Effect>
                </Button>
            </Grid>
        </Grid>

        <Rectangle Grid.Column="1" Width="2" Fill="#1A1A2E" Margin="0,5"/>

        <Grid Grid.Column="2" Margin="10,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="10" BorderThickness="1" BorderBrush="#00FFFF" Background="#111126" Padding="10" Margin="0,0,0,10">
                <TextBlock Text="SECURITY TASKS WORKBOARD" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="#00FFFF" FontWeight="Bold" FontSize="14">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#00FFFF" BlurRadius="5" ShadowDepth="0"/>
                    </TextBlock.Effect>
                </TextBlock>
            </Border>

            <DataGrid x:Name="TasksDataGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False"
                      Background="#111126" Foreground="White" RowBackground="#1A1A35" AlternatingRowBackground="#222240"
                      BorderBrush="#BF40BF" HorizontalGridLinesBrush="#2D2D44" VerticalGridLinesBrush="#2D2D44"
                      HeadersVisibility="Column" SelectionMode="Single">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#BF40BF"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="5"/>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Task Title" Binding="{Binding Title}" Width="130" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="150" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Reminder Frame" Binding="{Binding Reminder}" Width="110" IsReadOnly="True"/>
                    <DataGridCheckBoxColumn Header="Done" Binding="{Binding IsCompleted}" Width="50" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>

            <Grid Grid.Row="2" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="COMPLETE TASK" Height="40" Margin="0,0,5,0"
                        Click="CompleteTaskButton_Click" Background="#28A745" Foreground="White" FontWeight="Bold" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Grid.Column="1" Content="DELETE TASK" Height="40" Margin="5,0,5,0"
                        Click="DeleteTaskButton_Click" Background="#DC3545" Foreground="White" FontWeight="Bold" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Grid.Column="2" Content="🔄 REFRESH" Height="40" Width="90" Margin="5,0,0,0"
                        Click="RefreshTasksButton_Click" Background="#00FFFF" Foreground="Black" FontWeight="Bold" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</Window>